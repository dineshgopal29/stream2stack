# ── Production (Supabase + Claude + OpenAI) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Local development (Docker Postgres + Ollama) ──────────────────────────────
# Set DATABASE_URL to bypass Supabase and use local Postgres.
# Set OLLAMA_BASE_URL to bypass Claude/OpenAI and use local Ollama.
# See backend/.env.local for a ready-to-use local config.
#
# DATABASE_URL=postgresql://stream2stack:password@localhost:5432/stream2stack
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_LLM_MODEL=gemma4
# OLLAMA_EMBED_MODEL=qwen3-embedding
# OLLAMA_EMBED_DIMENSIONS=1024

# ── Shared ────────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000

# ── Cron / Scheduled Jobs ────────────────────────────────────────────────────
# Shared secret sent in X-Cron-Secret header by your scheduler.
# Leave blank to disable auth (local dev only).
CRON_SECRET=

# ── Firecrawl (web content extraction) ───────────────────────────────────────
# Used to scrape web URLs supplied in source_urls during newsletter generation.
# Get a key at https://www.firecrawl.dev — falls back to httpx crawler if unset.
FIRECRAWL_API_KEY=

# ── Licensing (on-premises deployments only) ──────────────────────────────────
# Leave unset for SaaS mode (default). Set S2S_DEPLOY_MODE=onprem to enable
# cryptographic license enforcement at startup.
#
# S2S_DEPLOY_MODE=onprem
# S2S_LICENSE_KEY=S2S-<base64url_header>.<base64url_payload>.<base64url_signature>
# S2S_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
